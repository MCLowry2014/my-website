{
  "version": "1.0.0",
  "program": {
    "name": "Achievement Points",
    "shortName": "AP",
    "philosophy": "Xbox-style one-time unlocks with permanent AP totals."
  },
  "rules": {
    "oneTimeOnly": true,
    "apNeverDecreases": true,
    "difficultyScale": [
      { "key": "INTRO", "label": "Intro", "points": 10 },
      { "key": "EASY", "label": "Easy", "points": 20 },
      { "key": "MEDIUM", "label": "Medium", "points": 40 },
      { "key": "HARD", "label": "Hard", "points": 75 },
      { "key": "EXPERT", "label": "Expert", "points": 125 },
      { "key": "LEGENDARY", "label": "Legendary", "points": 200 },
      { "key": "MYTHIC", "label": "Mythic", "points": 0 }
    ]
  },
  "targets": {
    "topicsPerSubject": {
      "math": 3,
      "science": 3,
      "history": 3,
      "english": 3,
      "coding": 3
    },
    "totalTopics": 15,
    "requiredGames": ["memory", "2048"]
  },
  "achievements": [
    {
      "id": "FIRST_UNLOCK",
      "name": "First Unlock",
      "description": "Unlock your first achievement.",
      "category": "platform",
      "difficulty": "INTRO",
      "points": 10,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "platform.eventsProcessed", "value": 1 }
    },
    {
      "id": "FIRST_TOPIC",
      "name": "First Steps",
      "description": "Complete your first education topic.",
      "category": "education",
      "difficulty": "EASY",
      "points": 20,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "education.topicsCompleted", "value": 1 }
    },
    {
      "id": "TOPIC_MASTER_80",
      "name": "Mastery Start",
      "description": "Score 80% or higher on any topic quiz.",
      "category": "education",
      "difficulty": "EASY",
      "points": 20,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "education.quizScores80OrHigher", "value": 1 }
    },
    {
      "id": "TOPIC_PERFECT",
      "name": "Perfect Lesson",
      "description": "Score 100% on any topic quiz.",
      "category": "education",
      "difficulty": "MEDIUM",
      "points": 40,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "education.quizPerfectCount", "value": 1 }
    },
    {
      "id": "QUIZ_STREAK_3",
      "name": "Three In A Row",
      "description": "Get 80%+ on 3 quizzes in a row.",
      "category": "education",
      "difficulty": "MEDIUM",
      "points": 40,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "education.bestQuiz80Streak", "value": 3 }
    },
    {
      "id": "QUIZ_STREAK_10",
      "name": "Quiz Machine",
      "description": "Get 80%+ on 10 quizzes in a row.",
      "category": "education",
      "difficulty": "EXPERT",
      "points": 125,
      "oneTime": true,
      "criteria": { "rule": "stat_at_least", "stat": "education.bestQuiz80Streak", "value": 10 }
